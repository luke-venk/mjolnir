# Ignore local data mounted to Docker container, but keep the actual directory.
data/*
!data/.gitkeep

# Python files.
venv/
__pycache__/

# Rust files.
target/
rust-project.json

# Bazel files.
# No trailing / since these are symlinks, not directories.
bazel-bin
bazel-out
bazel-testlogs
bazel-mjolnir
*.bazel.lock

**/.DS_Store

*.csv
*.jpg
*.png

# Test artifacts produced by scripts/test_pr78.sh (logs, captured PGMs).
.pr78-test-logs/
