# Ignore local data mounted to Docker container, but keep the actual directory.
data/*
!data/.gitkeep

# Python files.
venv/
__pycache__/

# Rust files (e.g. accidental `cargo` output under a crate).
target/
rust-project.json

# Bazel output symlinks at repo root (bazel-bin, bazel-out, bazel-testlogs,
# bazel-<workspace>, etc.). Leading / limits this to the repository root.
/bazel-*

# macOS
.DS_Store
