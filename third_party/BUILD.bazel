generate_visibility_header(
    name = "glib_visibility",
    out = "glib/glib/glib-visibility.h",
    namespace = "GLIB",
    version = "2.88.0",
)

cc_library(
    name = "glib",
    srcs = glob(
        [
            "glib/glib/*.c",
            "glib/glib/libcharset/*.c",
            "glib/glib/deprecated/*.c",
        ],
        exclude = [
            "glib/glib/gdbus-daemon.c",
            "glib/glib/gstdio-private.c",
            "glib/glib/giowin32.c",
            "glib/glib/gspawn-win32.c",
            "glib/glib/gspawn-win32-helper.c",
            "glib/glib/gthread-win32.c",
            "glib/glib/twin32.c",
            "glib/glib/gwin32.c",
            "glib/glib/win_iconv.c",
            "glib/glib/gutils-os2.c",
        ],
    ),
    hdrs = glob([
        "glib/glib/*.h",
        "glib/glib/libcharset/*.h",
        "glib/glib/deprecated/*.h",
    ]) + [
        "glib/glib/glib-visibility.h",
        "glib/glib/gthread-posix.c",
        "glib/glib/gversionmacros.h",
        ":glib_generated_config",
        ":glib_generated_glibconfig",
    ],
    copts = [
        "-DHAVE_LIBMOUNT=0",
        "-pthread",
        "-Wno-unknown-pragmas",
        "-D_REENTRANT",
        "-include",
        "glib/glib/glib.h",
        "-fvisibility=hidden",
        "-ffunction-sections",
        "-fdata-sections",
        "-O2",
    ] + select({
        "@platforms//os:linux": ["-D_GNU_SOURCE"],
        "@platforms//os:macos": ["-D_DARWIN_C_SOURCE"],
        "//conditions:default": [],
    }),
    defines = [
        "GLIB_MAJOR_VERSION=2",
        "LIBDIR=\\\"/usr/local/lib\\\"",
        "GLIB_CHARSETALIAS_DIR=\\\"/usr/local/lib\\\"",
        "GLIB_COMPILATION",
        "G_DISABLE_CAST_CHECKS",
        "HAVE_CONFIG_H",
        "G_LOG_DOMAIN=\\\"GLib\\\"",
    ],
    includes = [
        ".",
        "glib",
        "glib/glib",
        "glib_generated_includes",
        "glib_generated_includes/glib",
    ],
    linkopts = [
        "-pthread",
        "-lm",
    ] + select({
        "//:darwin_arm64": [
            "-liconv",
            "-framework CoreFoundation",
            "-framework Carbon",
            "-framework Foundation",
        ],
        "//:linux_arm64": ["-lrt"],
        "//:linux_amd64": ["-lrt"],
    }),
    deps = [
        ":pcre2",  # GLib's regex engine
        ":zlib",  # Used in various utilities
    ],
)

