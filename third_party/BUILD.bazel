load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_foreign_cc//foreign_cc:configure.bzl", "configure_make")

filegroup(
    name = "libffi_platform_headers",
    srcs = select({
        "//:darwin_arm64": glob(["libffi_per_platform_build_files/darwin_arm64/*.h"]),
        "//:linux_arm64": glob(["libffi_per_platform_build_files/linux_arm64/*.h"]),
        "//:linux_amd64": glob(["libffi_per_platform_build_files/linux_amd64/*.h"]),
    }),
)

cc_library(
    name = "libffi",
    srcs = glob(
        ["libffi/src/*.c"],
        exclude = ["libffi/src/java_raw_api.c"],
    ) + select({
        "//:darwin_arm64": glob(
            [
                "libffi/src/aarch64/*.S",
                "libffi/src/aarch64/*.c",
                "libffi/src/aarch64/*.h",
            ],
            exclude = ["libffi/src/aarch64/win64_armasm.S"],
        ),
        "//:linux_arm64": glob(
            [
                "libffi/src/aarch64/*.S",
                "libffi/src/aarch64/*.c",
                "libffi/src/aarch64/*.h",
            ],
            exclude = ["libffi/src/aarch64/win64_armasm.S"],
        ),
        "//:linux_amd64": glob(
            [
                "libffi/src/x86/*.S",
                "libffi/src/x86/*.c",
                "libffi/src/x86/*.h",
            ],
            exclude = [
                "libffi/src/x86/win64_intel.S",
                "libffi/src/x86/win64.S",
            ],
        ),
    }),
    hdrs = [":libffi_platform_headers"] + [
        "libffi/include/ffi_cfi.h",
        "libffi/include/ffi_common.h",
        "libffi/include/tramp.h",
    ],
    copts = [
        "-fvisibility=hidden",
        "-ffunction-sections",
        "-fdata-sections",
        "-O2",
        "-pthread",
        "-Wno-unknown-pragmas",
        "-D_REENTRANT",
    ] + select({
        "@platforms//os:linux": ["-D_GNU_SOURCE"],
        "@platforms//os:macos": ["-D_DARWIN_C_SOURCE"],
        "//conditions:default": [],
    }),
    defines = ["FFI_BUILDING"],
    includes = [
        "libffi/include",
    ] + select({
        "//:darwin_arm64": ["libffi_per_platform_build_files/darwin_arm64"],
        "//:linux_arm64": ["libffi_per_platform_build_files/linux_arm64"],
        "//:linux_amd64": ["libffi_per_platform_build_files/linux_amd64"],
    }),
    linkopts = [
        "-pthread",
        "-lm",
    ],
)

