genrule(
    name = "configure_gdbus_codegen_config",
    srcs = ["glib/gio/gdbus-2.0/codegen/config.py.in"],
    outs = ["glib/gio/gdbus-2.0/codegen/config.py"],
    cmd = """
        sed -e 's/@VERSION@/2.88.0/g' \
            -e 's/@MAJOR_VERSION@/2/g' \
            -e 's/@MINOR_VERSION@/88/g' \
            $< > $@
    """,
)

genrule(
    name = "configure_gdbus_codegen",
    srcs = ["glib/gio/gdbus-2.0/codegen/gdbus-codegen.in"],
    outs = ["glib/gio/gdbus-codegen.py"],
    cmd = """
        sed -e 's/@PYTHON@/python3/g' \
            -e 's/@VERSION@/2.88.0/g' \
            -e 's/@DATADIR@/./g' \
            $< > $@
    """,
)

genrule(
    name = "generate_gdbus_daemon_sources",
    srcs = [
        "glib/gio/dbus-daemon.xml",
        ":configure_gdbus_codegen",
        ":configure_gdbus_codegen_config",
    ] + glob(["glib/gio/gdbus-2.0/codegen/*.py"]),
    outs = [
        "glib/gio/gdbus-daemon-generated.c",
        "glib/gio/gdbus-daemon-generated.h",
    ],
    cmd = """
        mkdir -p codegen_tmp/codegen
                for f in $(SRCS); do
            if [[ "$$f" == *.py ]]; then
                cp -f "$$f" codegen_tmp/codegen/
            fi
        done
        MAIN_SCRIPT="codegen_tmp/codegen/gdbus-codegen.py"
        export PYTHONPATH="$$PWD/codegen_tmp:$${PYTHONPATH:-}"
        python3 "$$MAIN_SCRIPT" \
            --interface-prefix org. \
            --c-namespace _G \
            --generate-c-code $(RULEDIR)/glib/gio/gdbus-daemon-generated \
            $(location glib/gio/dbus-daemon.xml)
    """,
)

genrule(
    name = "generate_xdp_dbus_sources",
    srcs = [
        "glib/gio/org.freedesktop.portal.Documents.xml",
        "glib/gio/org.freedesktop.portal.OpenURI.xml",
        "glib/gio/org.freedesktop.portal.ProxyResolver.xml",
        "glib/gio/org.freedesktop.portal.Trash.xml",
        ":configure_gdbus_codegen",
        ":configure_gdbus_codegen_config",
    ] + glob(["glib/gio/gdbus-2.0/codegen/*.py"]),
    outs = [
        "xdp-dbus.c",
        "xdp-dbus.h",
    ],
    cmd = """
        mkdir -p codegen_tmp/codegen
        for f in $(SRCS); do
            if [[ "$$f" == *.py ]]; then
                cp -f "$$f" codegen_tmp/codegen/
            fi
        done
        
        MAIN_SCRIPT="codegen_tmp/codegen/gdbus-codegen.py"
        export PYTHONPATH="$$PWD/codegen_tmp:$${PYTHONPATH:-}"
        
        python3 "$$MAIN_SCRIPT" \
            --interface-prefix org.freedesktop.portal. \
            --c-namespace GXdp \
            --generate-c-code $(RULEDIR)/xdp-dbus \
            $(location glib/gio/org.freedesktop.portal.Documents.xml) \
            $(location glib/gio/org.freedesktop.portal.OpenURI.xml) \
            $(location glib/gio/org.freedesktop.portal.ProxyResolver.xml) \
            $(location glib/gio/org.freedesktop.portal.Trash.xml)
    """,
)

