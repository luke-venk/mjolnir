genrule(
    name = "glib_generated_includes",
    srcs = select({
        "//:darwin_arm64": glob([
            "glib_per_platform_build_files/darwin_arm64/*.h",
            "glib_per_platform_build_files/glib/darwin_arm64/*.h",
        ]),
        "//:linux_arm64": glob([
            "glib_per_platform_build_files/linux_arm64/*.h",
            "glib_per_platform_build_files/glib/linux_arm64/*.h",
        ]),
        "//:linux_amd64": glob([
            "glib_per_platform_build_files/linux_amd64/*.h",
            "glib_per_platform_build_files/glib/linux_amd64/*.h",
        ]),
    }),
    outs = [
        "glib_generated_includes/config.h",
        "glib_generated_includes/glib/glibconfig.h",
    ],
    cmd = select({
        "//:darwin_arm64": """
            cp $(location glib_per_platform_build_files/darwin_arm64/config.h) $(location glib_generated_includes/config.h)
            cp $(location glib_per_platform_build_files/glib/darwin_arm64/glibconfig.h) $(location glib_generated_includes/glib/glibconfig.h)
        """,
        "//:linux_arm64": """
            cp $(location glib_per_platform_build_files/linux_arm64/config.h) $(location glib_generated_includes/config.h)
            cp $(location glib_per_platform_build_files/glib/linux_arm64/glibconfig.h) $(location glib_generated_includes/glib/glibconfig.h)
        """,
        "//:linux_amd64": """
            cp $(location glib_per_platform_build_files/linux_amd64/config.h) $(location glib_generated_includes/config.h)
            cp $(location glib_per_platform_build_files/glib/linux_amd64/glibconfig.h) $(location glib_generated_includes/glib/glibconfig.h)
        """,
    }),
)

