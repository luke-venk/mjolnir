            "-lrt",
            "-lm",
            "-lpthread",
            "-Wl,--gc-sections",
        ],
        "@platforms//os:macos": [
            "-Wl,-dead_strip",
        ],
        "//conditions:default": [],
    }),
    deps = [
        ":pcre2",
        ":zlib",
    ],
)

