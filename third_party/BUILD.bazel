genrule(
    name = "generate_gmoduleconf",
    srcs = ["glib/gmodule/gmoduleconf.h.in"],
    outs = ["glib/gmodule/gmoduleconf.h"],
    cmd = """
        sed -e 's/@G_MODULE_IMPL@/1/g' \
