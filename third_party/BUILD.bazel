#define GLIB_VERSION_2_54 (G_ENCODE_VERSION(2, 54))\\n\\
#define GLIB_VERSION_2_56 (G_ENCODE_VERSION(2, 56))\\n\\
#define GLIB_VERSION_2_58 (G_ENCODE_VERSION(2, 58))\\n\\
#define GLIB_VERSION_2_60 (G_ENCODE_VERSION(2, 60))\\n\\
#define GLIB_VERSION_2_62 (G_ENCODE_VERSION(2, 62))\\n\\
#define GLIB_VERSION_2_64 (G_ENCODE_VERSION(2, 64))\\n\\
#define GLIB_VERSION_2_66 (G_ENCODE_VERSION(2, 66))\\n\\
#define GLIB_VERSION_2_68 (G_ENCODE_VERSION(2, 68))\\n\\
#define GLIB_VERSION_2_70 (G_ENCODE_VERSION(2, 70))\\n\\
