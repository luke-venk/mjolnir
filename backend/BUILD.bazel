load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")

rust_binary(
    name = "mjolnir",
    srcs = glob(["src/**/*.rs"]),
    deps = [
        "@crates//:axum",
        "@crates//:crossbeam",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:tokio",
    ],
)

rust_test(
    name = "tests",
    crate = ":mjolnir",
    deps = [
        "@crates//:axum",
        "@crates//:http-body-util",
        "@crates//:tower",
    ]
)
